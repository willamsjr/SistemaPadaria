<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="620.0" prefWidth="1010.0" style="-fx-background-color: #F5F5F5;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.EstoqueController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label layoutX="30.0" layoutY="30.0" text="Gestão de Estoque">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <VBox layoutX="30.0" layoutY="80.0" spacing="10.0">
            <Label text="Produtos Atuais">
                <font><Font name="System Bold" size="16.0" /></font>
            </Label>
            <TableView fx:id="tblProdutos" prefHeight="480.0" prefWidth="650.0">
                <columns>
                    <TableColumn fx:id="colProdutoId" prefWidth="75.0" text="ID" />
                    <TableColumn fx:id="colProdutoNome" prefWidth="300.0" text="Nome" />
                    <TableColumn fx:id="colProdutoPreco" prefWidth="125.0" text="Preço (R$)" />
                    <TableColumn fx:id="colProdutoQnt" prefWidth="150.0" text="Estoque Atual" />
                </columns>
            </TableView>
        </VBox>

        <VBox layoutX="700.0" layoutY="80.0" spacing="10.0" prefWidth="280.0">
            <Label text="Cadastrar Novo Produto">
                <font><Font name="System Bold" size="16.0" /></font>
            </Label>

            <Label text="Nome do Produto" />
            <TextField fx:id="txtNovoNome" promptText="Ex: Pão Francês" />

            <Label text="Preço (R$)" />
            <TextField fx:id="txtNovoPreco" promptText="Ex: 0.75" />

            <Label text="Quantidade em Estoque" />
            <TextField fx:id="txtNovoQnt" promptText="Ex: 300" />

            <Button fx:id="btnCadastrarProduto" mnemonicParsing="false" prefWidth="280.0" style="-fx-background-color: #27ae60;" text="CADASTRAR PRODUTO" textFill="WHITE">
                <font><Font name="System Bold" size="14.0" /></font>
                <VBox.margin>
                    <Insets top="20.0" />
                </VBox.margin>
            </Button>
        </VBox>

    </children>
</AnchorPane>